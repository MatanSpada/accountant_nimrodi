# Local development only. Do not commit real secrets.
APP_ENV=development
DEFAULT_PAYMENT_PROVIDER=mock-grow
GROW_MODE=mock
ALLOW_MOCK_GROW_IN_PRODUCTION=false
INVOICE_MODE=mock
ENABLE_DEV_TOOLS=true
PUBLIC_BASE_URL=http://127.0.0.1:8787
ADMIN_PASSWORD=dev-admin-password
SESSION_SECRET=dev-session-secret-change-me
# Make.com integration path for GROW. Leave empty until the scenario exists.
MAKE_CREATE_PAYMENT_LINK_WEBHOOK_URL=
MAKE_CREATE_PAYMENT_LINK_SECRET=
MAKE_APPROVE_TRANSACTION_WEBHOOK_URL=
MAKE_APPROVE_TRANSACTION_SECRET=
# Future real provider values. Leave empty until the client provides them.
GROW_USER_ID=
GROW_PAGE_CODE=
GROW_API_BASE_URL=
GROW_SUCCESS_URL=
GROW_CANCEL_URL=
GROW_NOTIFY_URL=
GROW_INVOICE_NOTIFY_URL=
GROW_API_KEY=
GROW_FORCE_BANK_TRANSFER_ONLY=false
INVOICE_PROVIDER_API_KEY=
CRM_API_KEY=
